      display: flex;
      flex-direction: column;
      gap: 20px;
      width: 90%;
      max-width: 450px;
    }

    .social-button {
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 18px 25px;
      border-radius: 15px;
      font-size: 1.2rem;
      font-weight: 700;
      text-decoration: none;
      color: #fff;
      transition: transform 0.3s, box-shadow 0.3s;
      box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }

    .social-button i {
      font-size: 30px;
      width: 35px;
      text-align: center;
    }

    .social-button:hover {
      transform: translateY(-5px) scale(1.02);
      box-shadow: 0 10px 25px rgba(0,0,0,0.4);
    }

